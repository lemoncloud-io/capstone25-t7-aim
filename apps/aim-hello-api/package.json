{
    "name": "aim-hello-api",
    "version": "0.25.1010",
    "description": "Simplified Boilerplate of Serverless API",
    "main": "dist/apps/aim-hello-api/src/index.js",
    "types": "dist/index.d.ts",
    "port": 8000,
    "scripts": {
        "build": "npm run build-ts",
        "build-ts": "ttsc",
        "watch-ts": "ttsc -w",
        "nodemon": "nodemon --config nodemon-main.json",
        "start": "npm run build && concurrently -k -p \"[{name}]\" -n \"TypeScript,Node\" -c \"cyan.bold,green.bold\" \"npm run watch-ts\" \"npm run nodemon\"",
        "test": "jest --config=jest.config.json",
        "test:watch": "jest --config=jest.config.json --watchAll"
    },
    "dependencies": {
        "lemon-core": "^4.0.7"
    },
    "devDependencies": {
        "@types/jest": "^27.5.0",
        "@types/node": "^17.0.42",
        "@types/supertest": "^2.0.10",
        "jest": "^27.5.1",
        "lemon-devkit": "^0.0.6",
        "nodemon": "^2.0.20",
        "superagent": "^5.3.1",
        "supertest": "^4.0.2",
        "ts-jest": "^27.1.5",
        "ts-node": "^8.1.0",
        "ts-transformer-keys": "^0.4.3",
        "tsconfig-paths": "^4.1.2",
        "ttypescript": "^1.5.15",
        "typescript": "^4.7.4"
    },
    "author": "Steve Jung <steve@lemoncloud.io> (https://eureka.codes)",
    "license": "ISC",
    "files": [
        "handler.js",
        "dist/**/*"
    ],
    "private": false
}
