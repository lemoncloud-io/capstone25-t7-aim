### Example env for backend (do NOT commit real secrets)
# Copy this to .env and fill real values for production

# AWS credentials (standard names used by AWS SDK)
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_DEFAULT_REGION=ap-northeast-2

# Optional: if you prefer different env var names used in older setups
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=ap-northeast-2
S3_BUCKET=aim-deploy-bucket

# App settings
MONGO_URI=mongodb://localhost:27017/aim
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=info

# LocalStack (for local testing)
# USE_LOCALSTACK=true
# LOCALSTACK_ENDPOINT=http://localhost:4566
# .env 파일

# AWS S3 설정 (필수)
S3_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_HERE
S3_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_KEY_HERE

# (선택 사항 - 기본값이 있지만 명시적으로 설정 가능)
S3_REGION=ap-northeast-2

# 기타 환경변수
MONGO_URI=mongodb://localhost:27017/aim
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=info